# Supabase (required for web). Get from: Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use SUPABASE_PUBLISHABLE_KEY (new) or SUPABASE_ANON_KEY (legacy, still supported)
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# SUPABASE_ANON_KEY=your-publishable-key  # Legacy name, still works

# Optional: web server port (default 8081)
# WEB_PORT=8081

# Optional: Google Places API key for address autocomplete when creating a building.
# Get from Google Cloud Console: enable Places API (Place Autocomplete). Without this, create-building still works with plain text.
# PLACES_API_KEY=your-google-places-api-key
